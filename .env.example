# 百度 AI 搜索 API（联网搜索，100次/天免费）
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SEARCH_BASE_URL=https://qianfan.baidubce.com/v2/ai_search

# DeepSeek API 配置（LLM 对话，直连备用）
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenCode Go API（优先使用，OpenAI 兼容代理）
# 从 https://opencode.ai/auth 获取 API Key
GO_API_KEY=your-go-api-key
GO_BASE_URL=https://opencode.ai/zen/go/v1
GO_MODEL=deepseek-v4-flash

# Embedding API 配置（阿里云百炼，OpenAI 兼容）
EMBEDDING_API_KEY=your-bailian-api-key
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 数据库路径
DATABASE_PATH=data/tickets.db

# ChromaDB 向量存储路径
CHROMA_PERSIST_DIR=chroma_data

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# LLM 参数
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096

# Agent 参数
MAX_RETRIES=3
MAX_ITERATIONS=5

# MCP Server 端口
MCP_SERVER_PORT=8000
